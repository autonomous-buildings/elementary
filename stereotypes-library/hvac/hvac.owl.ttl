                               elementary:OutletConnectionPoint ;
                      elementary:dealsWithStuff Brick:Air ;
                      elementary:isRelatedToVariable :var_air_flow_rate .


###  http://www.w3id.org/elmentary/applications/hvac#cp_drive_control_signal_input
:cp_drive_control_signal_input rdf:type owl:NamedIndividual ,

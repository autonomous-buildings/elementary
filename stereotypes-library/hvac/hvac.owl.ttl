###  http://www.w3id.org/elmentary/applications/hvac#downstream
:downstream rdf:type owl:NamedIndividual ,
                     elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#exhaust
:exhaust rdf:type owl:NamedIndividual ,
                  elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#extract
:extract rdf:type owl:NamedIndividual ,
                  elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#inlet
:inlet rdf:type owl:NamedIndividual ,
                elementary:ProcessPosition ;
       owl:sameAs :intake .


###  http://www.w3id.org/elmentary/applications/hvac#intake

###  http://www.w3id.org/elmentary/applications/hvac#intake
:intake rdf:type owl:NamedIndividual ,
                 elementary:ProcessPosition .


###  http://www.w3id.org/elmentary/applications/hvac#midstream
:midstream rdf:type owl:NamedIndividual ,
                    elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#outlet
:outlet rdf:type owl:NamedIndividual ,
                 elementary:ProcessPosition .


###  http://www.w3id.org/elmentary/applications/hvac#outside-air
:outside-air rdf:type owl:NamedIndividual ,
                      elementary:ProcessPosition .


###  http://www.w3id.org/elmentary/applications/hvac#pm_air_throttling
:pm_air_throttling rdf:type owl:NamedIndividual ,
                            elementary:PhysicalMechanism ;
                   elementary:hasDependentVariable :var_air_flow_rate ;
                   elementary:hasIndependentVariable :var_air_inlet_pressure ;
                   elementary:hasManipulatedVariable :var_orifice_opening_ratio .


###  http://www.w3id.org/elmentary/applications/hvac#pm_centrifugal_pressurization
:pm_centrifugal_pressurization rdf:type owl:NamedIndividual ,
                                        elementary:PhysicalMechanism ;
                               elementary:affectedUpstreamVariable :var_air_flow_rate ;
                               elementary:hasDependentVariable :var_air_flow_rate ,
                                                               :var_air_outlet_pressure ;
                               elementary:hasIndependentVariable :var_air_inlet_pressure ;
                               elementary:hasManipulatedVariable :var_shaft_power .


###  http://www.w3id.org/elmentary/applications/hvac#pm_convective_heat_transfer
:pm_convective_heat_transfer rdf:type owl:NamedIndividual ,
                                      elementary:PhysicalMechanism ;
                             elementary:hasDependentVariable :var_air_outlet_temperature ,
                                                             :var_water_outlet_temperature ;
                             elementary:hasIndependentVariable :var_air_flow_rate ,

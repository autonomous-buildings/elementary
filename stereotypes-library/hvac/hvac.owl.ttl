                                     elementary:OutletConnectionPoint ;
                            elementary:dealsWithStuff elementary:electrical_power ;
                            elementary:isRelatedToVariable :var_electrical_output_power .


###  http://www.w3id.org/elmentary/applications/hvac#cp_fan_air_inlet
:cp_fan_air_inlet rdf:type owl:NamedIndividual ,
                           elementary:InletConnectionPoint ;
                  elementary:dealsWithStuff Brick:Air ;
                  elementary:isRelatedToVariable :var_air_flow_rate ,
                                                 :var_air_inlet_pressure ;
                  elementary:suitableFor :air-side .


###  http://www.w3id.org/elmentary/applications/hvac#cp_fan_air_outlet

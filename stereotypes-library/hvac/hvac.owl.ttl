@prefix : <http://www.w3id.org/elmentary/applications/hvac#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix tso: <https://w3id.org/tso#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix Brick: <https://brickschema.org/schema/Brick#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix bacnet: <http://data.ashrae.org/bacnet/2020#> .
@prefix schema: <http://schema.org/> .
@prefix elementary: <http://www.w3id.org/elementary#> .
@base <http://www.w3id.org/elmentary/applications/hvac#> .

<http://www.w3id.org/elementary/applications/hvac> rdf:type owl:Ontology ;
                                                    owl:imports <http://www.w3id.org/elementary> ,
                                                                <https://brickschema.org/schema/1.3/Brick> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3id.org/elementary#effectiveAt
elementary:effectiveAt rdf:type owl:AnnotationProperty .


###  http://www.w3id.org/elementary#existence_xor
elementary:existence_xor rdf:type owl:AnnotationProperty .


###  http://www.w3id.org/elementary#isRelatedToStreamKind
elementary:isRelatedToStreamKind rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.w3id.org/elementary#ComponentAction
elementary:ComponentAction rdf:type owl:Class .


###  http://www.w3id.org/elementary#Container
elementary:Container rdfs:subClassOf Brick:Equipment .


###  http://www.w3id.org/elementary#InletConnectionPointConnectionPoint
elementary:InletConnectionPointConnectionPoint rdf:type owl:Class .


###  http://www.w3id.org/elementary#StreamJoiner
elementary:StreamJoiner rdfs:subClassOf Brick:Equipment .


###  http://www.w3id.org/elementary#StreamSplitter
elementary:StreamSplitter rdfs:subClassOf Brick:Equipment .


###  http://www.w3id.org/elmentary/applications/hvac#ConditionedSpace
:ConditionedSpace rdf:type owl:Class .


###  https://brickschema.org/schema/Brick#Equipment
Brick:Equipment rdfs:subClassOf elementary:Component .


###  https://brickschema.org/schema/Brick#VariableFrequencyDrive
Brick:VariableFrequencyDrive rdf:type owl:Class ;
                             rdfs:subClassOf Brick:Equipment ;
                             rdfs:label "VFD" .


###  https://w3id.org/tso#ConnectionPoint
tso:ConnectionPoint rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.w3id.org/elementary#electrical_power
elementary:electrical_power rdf:type owl:NamedIndividual .


###  http://www.w3id.org/elementary#var_control_signal
elementary:var_control_signal rdf:type owl:NamedIndividual ,
                                       elementary:ProcessVariable .


###  http://www.w3id.org/elmentary/applications/hvac#Opening_Ratio
:Opening_Ratio rdf:type owl:NamedIndividual ,
                        Brick:Quantity .


###  http://www.w3id.org/elmentary/applications/hvac#action_change_damper_position
:action_change_damper_position rdf:type owl:NamedIndividual ,
                                        elementary:ComponentAction ;
                               elementary:modulatedBy elementary:mechanical_force ;
                               elementary:modulates :var_orifice_opening_ratio ;
                               elementary:effectiveAt :cp_damper_actuation_input .


###  http://www.w3id.org/elmentary/applications/hvac#action_change_fan_power_input
:action_change_fan_power_input rdf:type owl:NamedIndividual ,
                                        elementary:ComponentAction ;
                               elementary:modulatedBy elementary:mechanical_energy ;
                               elementary:effectiveAt :cp_fan_shaft .


###  http://www.w3id.org/elmentary/applications/hvac#action_change_motor_power_output
:action_change_motor_power_output rdf:type owl:NamedIndividual ,
                                           elementary:ComponentAction ;
                                  elementary:modulatedBy elementary:electrical_energy ;
                                  elementary:effectiveAt :cp_motor_shaft .


###  http://www.w3id.org/elmentary/applications/hvac#action_change_valve_position
:action_change_valve_position rdf:type owl:NamedIndividual ,
                                       elementary:ComponentAction ;
                              elementary:modulatedBy elementary:mechanical_force ;
                              elementary:effectiveAt :cp_valve_actuation_input .


###  http://www.w3id.org/elmentary/applications/hvac#air-side
:air-side rdf:type owl:NamedIndividual ,
                   elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#bypass
:bypass rdf:type owl:NamedIndividual ,
                 elementary:StreamKind .


###  http://www.w3id.org/elmentary/applications/hvac#contained
:contained rdf:type owl:NamedIndividual ,
                    elementary:ProcessPosition .


###  http://www.w3id.org/elmentary/applications/hvac#cp_actuation_signal_input
:cp_actuation_signal_input rdf:type owl:NamedIndividual ,
                                    elementary:InletConnectionPoint ;
                           elementary:manipulates elementary:var_control_signal .


###  http://www.w3id.org/elmentary/applications/hvac#cp_actuator_electrical_energy_input
:cp_actuator_electrical_energy_input rdf:type owl:NamedIndividual ,
                                              elementary:InletConnectionPoint ;
                                     elementary:dealsWithStuff Brick:Electric_Energy ;
                                     elementary:hasObservedVariable :var_input_electrical_energy .


###  http://www.w3id.org/elmentary/applications/hvac#cp_actuator_mechanical_output
:cp_actuator_mechanical_output rdf:type owl:NamedIndividual ,
                                        elementary:OutletConnectionPoint .


###  http://www.w3id.org/elmentary/applications/hvac#cp_air-water-heat-exchanger_air-inlet
:cp_air-water-heat-exchanger_air-inlet rdf:type owl:NamedIndividual ,
                                                elementary:InletConnectionPoint ;
                                       elementary:hasSubstance Brick:Air ;
                                       elementary:isRelatedToVariable :var_secondary_fluid_inlet_temperature ,
                                                                      :var_secondary_fluid_through_flowrate ;
                                       elementary:isRelatedToStreamKind :secondary .


###  http://www.w3id.org/elmentary/applications/hvac#cp_air-water-heat-exchanger_air-outlet
:cp_air-water-heat-exchanger_air-outlet rdf:type owl:NamedIndividual ,
                                                 elementary:OutletConnectionPoint ;
                                        elementary:hasSubstance Brick:Air ;
                                        elementary:isRelatedToVariable :var_secondary_fluid_outlet_temperature ,
                                                                       :var_secondary_fluid_through_flowrate ;
                                        elementary:isRelatedToStreamKind :secondary .


###  http://www.w3id.org/elmentary/applications/hvac#cp_air-water-heat-exchanger_water-inlet
:cp_air-water-heat-exchanger_water-inlet rdf:type owl:NamedIndividual ,
                                                  elementary:InletConnectionPoint ;
                                         elementary:hasSubstance Brick:Water ;
                                         elementary:isRelatedToVariable :var_primary_fluid_inlet_temperature ,
                                                                        :var_primary_fluid_through_flowrate ;
                                         elementary:isRelatedToStreamKind :primary .


###  http://www.w3id.org/elmentary/applications/hvac#cp_air-water-heat-exchanger_water-outlet
:cp_air-water-heat-exchanger_water-outlet rdf:type owl:NamedIndividual ,
                                                   elementary:OutletConnectionPoint ;
                                          elementary:hasSubstance Brick:Water ;
                                          elementary:isRelatedToVariable :var_primary_fluid_outlet_temperature ,
                                                                         :var_primary_fluid_through_flowrate ;
                                          elementary:isRelatedToStreamKind :primary .


###  http://www.w3id.org/elmentary/applications/hvac#cp_air_heatexchange_surface
:cp_air_heatexchange_surface rdf:type owl:NamedIndividual ,
                                      elementary:ConnectionPoint ;
                             elementary:dealsWithStuff Brick:Air ;
                             elementary:isRelatedToVariable :var_output_energy ;
                             elementary:suitableFor :air-side .


###  http://www.w3id.org/elmentary/applications/hvac#cp_boiler_electrical_input
:cp_boiler_electrical_input rdf:type owl:NamedIndividual ,
                                     tso:ConnectionPoint ;
                            elementary:manipulates :var_electrical_input_power ;
                            rdfs:label "electrical-input" .


###  http://www.w3id.org/elmentary/applications/hvac#cp_boiler_water_inlet
:cp_boiler_water_inlet rdf:type owl:NamedIndividual ,
                                tso:ConnectionPoint ;
                       elementary:isRelatedToVariable :var_fluid_flow_rate ,
                                                      :var_water_inlet_temperature .


###  http://www.w3id.org/elmentary/applications/hvac#cp_boiler_water_outlet
:cp_boiler_water_outlet rdf:type owl:NamedIndividual ,
                                 tso:ConnectionPoint ;
                        elementary:isRelatedToVariable :var_fluid_flow_rate ,
                                                       :var_water_outlet_temperature .


###  http://www.w3id.org/elmentary/applications/hvac#cp_damper_actuation_input
:cp_damper_actuation_input rdf:type owl:NamedIndividual ,
                                    elementary:ActuationConnectionPoint ;
                           elementary:isRelatedToVariable :var_orifice_opening_ratio .


###  http://www.w3id.org/elmentary/applications/hvac#cp_damper_air_inlet
:cp_damper_air_inlet rdf:type owl:NamedIndividual ,
                              elementary:InletConnectionPoint ;
                     elementary:dealsWithStuff Brick:Air ;
                     elementary:isRelatedToVariable :var_air_flow_rate ,
                                                    :var_air_inlet_pressure .


###  http://www.w3id.org/elmentary/applications/hvac#cp_damper_air_outlet

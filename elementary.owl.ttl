<elementary> a owl:Ontology;
  <http://purl.org/dc/elements/1.1/creator> "Ganesh Ramanathan", "This ontology is distributed uner a Creative Commons Attribution License";
  <http://purl.org/dc/elements/1.1/date> "2024-07-01";
  <http://purl.org/dc/elements/1.1/description> "https://autonomous-buildings.github.io/elementary/diagrams/automation-overview.png"^^xsd:anyURI,
    "Elemenary is a high-level ontology that enables the creation of a holistic system description of electro-mechanical systems and its automation.";
  rdfs:comment "An ontology for describing electro-mechanical systems and its automation" .

<http://purl.org/dc/elements/1.1/author> a owl:AnnotationProperty .

<http://purl.org/dc/elements/1.1/creator> a owl:AnnotationProperty .


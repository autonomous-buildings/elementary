<http://purl.org/dc/elements/1.1/rights> a owl:AnnotationProperty .

<http://purl.org/dc/elements/1.1/title> a owl:AnnotationProperty .

owl:topObjectProperty owl:inverseOf :measures .

:achieves a owl:ObjectProperty;
  rdfs:subPropertyOf :modulates .

:affectedUpstreamVariable a owl:ObjectProperty;
  owl:equivalentProperty :upstreamEffect;
  rdfs:subPropertyOf :physicalProcessRelation;
  owl:propertyChainAxiom _:genid3 .


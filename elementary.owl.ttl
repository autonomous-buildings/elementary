@prefix : <http://www.w3id.org/elementary#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3id.org/elementary#> .

<http://www.w3id.org/elementary> rdf:type owl:Ontology ;
                                  <http://purl.org/dc/elements/1.1/creator> "Ganesh Ramanathan" ,
                                                                            "This ontology is distributed uner a Creative Commons Attribution License" ;
                                  <http://purl.org/dc/elements/1.1/date> "2024-07-01" ;
                                  <http://purl.org/dc/elements/1.1/description> "https://autonomous-buildings.github.io/elementary/diagrams/automation-overview.png"^^xsd:anyURI ,
                                                                                "Elemenary is a high-level ontology that enables the creation of a holistic system description of electro-mechanical systems and its automation." ;
                                  rdfs:comment "An ontology for describing electro-mechanical systems and its automation" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/author
<http://purl.org/dc/elements/1.1/author> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/rights
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty owl:inverseOf :measures .


###  http://www.w3id.org/elementary#achieves
:achieves rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :modulates .


###  http://www.w3id.org/elementary#affectedUpstreamVariable
:affectedUpstreamVariable rdf:type owl:ObjectProperty ;
                          owl:equivalentProperty :upstreamEffect ;
                          rdfs:subPropertyOf :physicalProcessRelation ;
                          owl:propertyChainAxiom ( :hasStereotype
                                                   :hasPhysicalMechanism
                                                   :affectedUpstreamVariable
                                                 ) .


###  http://www.w3id.org/elementary#affects
:affects rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#assignedTo
:assignedTo rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :requirementsRelation .


###  http://www.w3id.org/elementary#associatedTo
:associatedTo rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#automatedBy
:automatedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#automates
:automates rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#automationRelation
:automationRelation rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#avoids
:avoids rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :modulates .


###  http://www.w3id.org/elementary#bidirectionallyLinkedTo
:bidirectionallyLinkedTo rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :linkedTo .


###  http://www.w3id.org/elementary#byMeansOf
:byMeansOf rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :requirementsRelation ;
           owl:inverseOf :fulfills .


###  http://www.w3id.org/elementary#conflictsWithGoal
:conflictsWithGoal rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#connectedAcross
:connectedAcross rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#connectedThrough
:connectedThrough rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#connectsSystemThrough
:connectsSystemThrough rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#connectsTo
:connectsTo rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :associatedTo ;
            rdf:type owl:SymmetricProperty .


###  http://www.w3id.org/elementary#contains
:contains rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasTopologicalRelationTo ;
          rdfs:label "contains" .


###  http://www.w3id.org/elementary#datapointOf
:datapointOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#dealsWithStuff
:dealsWithStuff rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :physicalProcessRelation ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :ConnectionPoint
                                            :ProcessVariable
                                          )
                            ] ;
                rdfs:range :PhysicalStuff .


###  http://www.w3id.org/elementary#decreases
:decreases rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :modulates .


###  http://www.w3id.org/elementary#derivedFrom
:derivedFrom rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#describedBy
:describedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :automationRelation ;
             rdfs:domain :ControlProgram ;
             rdfs:range :ProgramModel .


###  http://www.w3id.org/elementary#directProportion
:directProportion rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :affects .


###  http://www.w3id.org/elementary#downlink
:downlink rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasNetworkLink .


###  http://www.w3id.org/elementary#effectiveAtPort
:effectiveAtPort rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :relatedToPort ;
                 rdfs:comment "Relates an acutator to the port of a component where the action is effective" .


###  http://www.w3id.org/elementary#enablesGoal
:enablesGoal rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#existence_and
:existence_and rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_cannotCoexistWith
:existence_cannotCoexistWith rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_hasToExistInTheAbsenceOf
:existence_hasToExistInTheAbsenceOf rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_hasToExistInThePresenceOf
:existence_hasToExistInThePresenceOf rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_implies
:existence_implies rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_mayCoexistsWith
:existence_mayCoexistsWith rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf :variantCondition ;
                           rdf:type owl:SymmetricProperty .


###  http://www.w3id.org/elementary#existence_mayExistOnlyWhenAbsent
:existence_mayExistOnlyWhenAbsent rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_mayOnlyExistInThePresenceOf
:existence_mayOnlyExistInThePresenceOf rdf:type owl:ObjectProperty ;
                                       rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_mustCoexistWith
:existence_mustCoexistWith rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#existence_or
:existence_or rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :variantCondition ;
              rdf:type owl:SymmetricProperty .


###  http://www.w3id.org/elementary#existence_xor
:existence_xor rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :variantCondition ;
               rdf:type owl:SymmetricProperty .


###  http://www.w3id.org/elementary#faultDetectionRelation
:faultDetectionRelation rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#fedBy
:fedBy rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :hasFlowRelationTo ;
       owl:inverseOf :feeds ;
       rdfs:label "fed by" .


###  http://www.w3id.org/elementary#feeds
:feeds rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :hasFlowRelationTo ;
       owl:propertyChainAxiom ( :hasConnectionPoint
                                :feeds
                                :isConnectionPointOf
                              ) ;
       rdfs:label "feeds" .


###  http://www.w3id.org/elementary#fulfills
:fulfills rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :requirementsRelation .


###  http://www.w3id.org/elementary#hasCausationAction
:hasCausationAction rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :systemDesignRelation ;
                    rdfs:domain :ConnectionPoint ;
                    rdfs:range :ProcessAction .


###  http://www.w3id.org/elementary#hasComponentAction
:hasComponentAction rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :systemDesignRelation ;
                    rdfs:domain :Component .


###  http://www.w3id.org/elementary#hasConnectionPoint
:hasConnectionPoint rdf:type owl:ObjectProperty ;
                    owl:equivalentProperty :hasPort ;
                    rdfs:subPropertyOf :systemDesignRelation ;
                    owl:inverseOf :isConnectionPointOf ;
                    owl:propertyChainAxiom ( :hasStereotype
                                             :hasConnectionPoint
                                           ) ;
                    rdfs:comment "has port" ;
                    rdfs:label "has port" .


###  http://www.w3id.org/elementary#hasControlInput
:hasControlInput rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :hasConnectionPoint .


###  http://www.w3id.org/elementary#hasControlOutput
:hasControlOutput rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :hasConnectionPoint .


###  http://www.w3id.org/elementary#hasControlledVariable
:hasControlledVariable rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasVariable .


###  http://www.w3id.org/elementary#hasDependentVariable
:hasDependentVariable rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :hasVariable ;
                      rdfs:comment "The variable that changes as an outcome of the process" .


###  http://www.w3id.org/elementary#hasEffect
:hasEffect rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasEffectAssertion
:hasEffectAssertion rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasEffectPrecondition
:hasEffectPrecondition rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasFailureCause
:hasFailureCause rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasFailureEffect
:hasFailureEffect rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasFailureMode
:hasFailureMode rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasFaultMode
:hasFaultMode rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasFlowRelationTo
:hasFlowRelationTo rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#hasFunctionalRole
:hasFunctionalRole rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasGoal
:hasGoal rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :requirementsRelation ;
         rdfs:domain :Requirement ;
         rdfs:range :Goal .


###  http://www.w3id.org/elementary#hasHardwareInterface
:hasHardwareInterface rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasIndependentVariable
:hasIndependentVariable rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :hasVariable ;
                        rdfs:comment "The variable that can be changed by an external agent" .


###  http://www.w3id.org/elementary#hasInlet
:hasInlet rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasConnectionPoint ;
          owl:propertyChainAxiom ( :hasConnectionPoint
                                 ) .


###  http://www.w3id.org/elementary#hasInput
:hasInput rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasInterface ;
          rdfs:domain :ControlProgram .


###  http://www.w3id.org/elementary#hasInputEnergy
:hasInputEnergy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :dealsWithStuff .


###  http://www.w3id.org/elementary#hasInterface
:hasInterface rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasInvariant
:hasInvariant rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasManipulatedVariable
:hasManipulatedVariable rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :hasIndependentVariable ;
                        rdfs:comment "The variable that is foreseen to be manipulated by an external agent" .


###  http://www.w3id.org/elementary#hasMechanism
:hasMechanism rdf:type owl:ObjectProperty ;
              owl:equivalentProperty :hasPhysicalMechanism ;
              rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasMitigation
:hasMitigation rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasNetworkInterface
:hasNetworkInterface rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasNetworkLink
:hasNetworkLink rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#hasObservedVariable
:hasObservedVariable rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :isRelatedToVariable .


###  http://www.w3id.org/elementary#hasOptionalSubGoal
:hasOptionalSubGoal rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasSubGoal .


###  http://www.w3id.org/elementary#hasOutlet
:hasOutlet rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasConnectionPoint .


###  http://www.w3id.org/elementary#hasOutput
:hasOutput rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :hasInterface ;
           rdfs:domain :ControlProgram .


###  http://www.w3id.org/elementary#hasOutputEnergy
:hasOutputEnergy rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :dealsWithStuff .


###  http://www.w3id.org/elementary#hasParameter
:hasParameter rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :hasInterface ;
              rdfs:domain :ControlProgram .


###  http://www.w3id.org/elementary#hasPart
:hasPart rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :hasTopologicalRelationTo ;
         owl:inverseOf :isPartOf ;
         rdfs:label "has part" .


###  http://www.w3id.org/elementary#hasPhaseState
:hasPhaseState rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasPhysicalMechanism
:hasPhysicalMechanism rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :physicalProcessRelation ;
                      owl:propertyChainAxiom ( :hasStereotype
                                               :hasPhysicalMechanism
                                             ) .


###  http://www.w3id.org/elementary#hasPort
:hasPort rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :systemDesignRelation ;
         owl:inverseOf :isPortOf ;
         rdfs:label "has port" .


###  http://www.w3id.org/elementary#hasPosition
:hasPosition rdf:type owl:ObjectProperty ;
             owl:equivalentProperty :hasProcessPosition ;
             rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasPostcondition
:hasPostcondition rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasPrecondition
:hasPrecondition rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasPrimaryDependentVariable
:hasPrimaryDependentVariable rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf :hasDependentVariable .


###  http://www.w3id.org/elementary#hasProcessAction
:hasProcessAction rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasProcessPathway
:hasProcessPathway rdf:type owl:ObjectProperty ;
                   owl:equivalentProperty :isRelatedToStreamKind ;
                   rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasProcessPosition
:hasProcessPosition rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasQuantity
:hasQuantity rdf:type owl:ObjectProperty ;
             owl:equivalentProperty :hasQuantityKind ;
             rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasQuantityKind
:hasQuantityKind rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasRequiredSubGoal
:hasRequiredSubGoal rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasSubGoal .


###  http://www.w3id.org/elementary#hasRequirement
:hasRequirement rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :requirementsRelation .


###  http://www.w3id.org/elementary#hasSignalType
:hasSignalType rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasSimulationModel
:hasSimulationModel rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasStateLabel
:hasStateLabel rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasStereotype
:hasStereotype rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasStreamKind
:hasStreamKind rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :systemDesignRelation ;
               rdfs:domain :Stream ;
               rdfs:range :StreamKind .


###  http://www.w3id.org/elementary#hasStruturalStereotype
:hasStruturalStereotype rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#hasSubGoal
:hasSubGoal rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#hasSubstance
:hasSubstance rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :dealsWithStuff .


###  http://www.w3id.org/elementary#hasTarget
:hasTarget rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#hasTemporalSpecification
:hasTemporalSpecification rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :faultDetectionRelation .


###  http://www.w3id.org/elementary#hasTopologicalRelationTo
:hasTopologicalRelationTo rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#hasUnits
:hasUnits rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasUpstreamEffectOn
:hasUpstreamEffectOn rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasVariable
:hasVariable rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#hasVariant
:hasVariant rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#hostedBy
:hostedBy rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :automationRelation ;
          owl:inverseOf :hostsProgram .


###  http://www.w3id.org/elementary#hostsProgram
:hostsProgram rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation ;
              rdfs:domain :AutomationController ;
              rdfs:range :ControlProgram .


###  http://www.w3id.org/elementary#increases
:increases rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :modulates .


###  http://www.w3id.org/elementary#inverseProportion
:inverseProportion rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :affects .


###  http://www.w3id.org/elementary#isActivatedByGoal
:isActivatedByGoal rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#isCompatibleTo
:isCompatibleTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#isConnectionPointOf
:isConnectionPointOf rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :systemDesignRelation ;
                     rdfs:label "is port of" .


###  http://www.w3id.org/elementary#isConstrainedByRequirement
:isConstrainedByRequirement rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf :isRelatedToRequirement .


###  http://www.w3id.org/elementary#isContainedIn
:isContainedIn rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :hasTopologicalRelationTo ;
               rdfs:label "contained in" .


###  http://www.w3id.org/elementary#isDeactivatedByGoal
:isDeactivatedByGoal rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#isEnabledByRequirement
:isEnabledByRequirement rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :isRelatedToRequirement .


###  http://www.w3id.org/elementary#isFlowCompatibleTo
:isFlowCompatibleTo rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :isCompatibleTo .


###  http://www.w3id.org/elementary#isIntendedFor
:isIntendedFor rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#isObservedBy
:isObservedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :automationRelation ;
              owl:inverseOf :observes .


###  http://www.w3id.org/elementary#isPartOf
:isPartOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasTopologicalRelationTo ;
          rdfs:label "is part of" .


###  http://www.w3id.org/elementary#isPortOf
:isPortOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :systemDesignRelation ;
          rdfs:label "is port of" .


###  http://www.w3id.org/elementary#isRelatedToGoal
:isRelatedToGoal rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :requirementsRelation .


###  http://www.w3id.org/elementary#isRelatedToRequirement
:isRelatedToRequirement rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf :requirementsRelation .


###  http://www.w3id.org/elementary#isRelatedToStreamKind
:isRelatedToStreamKind rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#isRelatedToVariable
:isRelatedToVariable rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :physicalProcessRelation ,
                                        :requirementsRelation .


###  http://www.w3id.org/elementary#linkedTo
:linkedTo rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#maintains
:maintains rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :modulates .


###  http://www.w3id.org/elementary#mandatoryIfExists
:mandatoryIfExists rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#manipulates
:manipulates rdf:type owl:ObjectProperty ;
             owl:equivalentProperty :modulates ;
             rdfs:subPropertyOf :isRelatedToVariable .


###  http://www.w3id.org/elementary#measures
:measures rdf:type owl:ObjectProperty ;
          owl:equivalentProperty :observes ;
          rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#modulatedBy
:modulatedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#modulates
:modulates rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :automationRelation ;
           owl:propertyChainAxiom ( :hasPhysicalMechanism
                                    :hasDependentVariable
                                  ) .


###  http://www.w3id.org/elementary#mustBeAchievedAfter
:mustBeAchievedAfter rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#mustBeAchievedBefore
:mustBeAchievedBefore rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :isRelatedToGoal .


###  http://www.w3id.org/elementary#observes
:observes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#observesAtInletOf
:observesAtInletOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :observes .


###  http://www.w3id.org/elementary#observesAtOutletOf
:observesAtOutletOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :observes .


###  http://www.w3id.org/elementary#observesAtPort
:observesAtPort rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :relatedToPort ;
                rdfs:comment "Relates a sensor to a port where a variable is observed" .


###  http://www.w3id.org/elementary#observesInContainmentOf
:observesInContainmentOf rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :observes .


###  http://www.w3id.org/elementary#optionalIfExists
:optionalIfExists rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :variantCondition .


###  http://www.w3id.org/elementary#physicalProcessRelation
:physicalProcessRelation rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#precedes
:precedes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasTopologicalRelationTo ;
          owl:inverseOf :succedes .


###  http://www.w3id.org/elementary#refersTo
:refersTo rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#relatedToPort
:relatedToPort rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :systemDesignRelation ;
               rdfs:comment "A peripheral (sensor or actuator) may be related to a port in such a way that the variable it act upon or observes is primarily located at the port. For example, to state heating coil air outlet temperature, or pump inlet valve." .


###  http://www.w3id.org/elementary#representedBy
:representedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#represents
:represents rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :automationRelation .


###  http://www.w3id.org/elementary#requirementsRelation
:requirementsRelation rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#separates
:separates rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :systemDesignRelation .


###  http://www.w3id.org/elementary#succedes
:succedes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :hasTopologicalRelationTo .


###  http://www.w3id.org/elementary#suitableFor
:suitableFor rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :hasStreamKind .


###  http://www.w3id.org/elementary#systemDesignRelation
:systemDesignRelation rdf:type owl:ObjectProperty .


###  http://www.w3id.org/elementary#unidirectionallyLinkedTo
:unidirectionallyLinkedTo rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :linkedTo .


###  http://www.w3id.org/elementary#uplink
:uplink rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasNetworkLink .


###  http://www.w3id.org/elementary#upstreamEffect
:upstreamEffect rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :physicalProcessRelation .


###  http://www.w3id.org/elementary#variantCondition
:variantCondition rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :systemDesignRelation .



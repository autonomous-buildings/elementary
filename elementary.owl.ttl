#    Data properties
#################################################################

###  http://www.w3id.org/elementary#atLeast
:atLeast rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :variantConditionQuantification .


###  http://www.w3id.org/elementary#atTheMost
:atTheMost rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :variantConditionQuantification .


###  http://www.w3id.org/elementary#componentProperty
:componentProperty rdf:type owl:DatatypeProperty .


###  http://www.w3id.org/elementary#exactly
:exactly rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :variantConditionQuantification .


###  http://www.w3id.org/elementary#externalResource
:externalResource rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty .


###  http://www.w3id.org/elementary#failureDetecability
:failureDetecability rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf :faultQuantification .


###  http://www.w3id.org/elementary#failureEffectDescription
:failureEffectDescription rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf :faultQualification .


###  http://www.w3id.org/elementary#failureEffectSeverity
:failureEffectSeverity rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf :faultQuantification .


###  http://www.w3id.org/elementary#failureProbability
:failureProbability rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :faultQuantification .


###  http://www.w3id.org/elementary#faultProperty
:faultProperty rdf:type owl:DatatypeProperty .


###  http://www.w3id.org/elementary#faultQualification
:faultQualification rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :faultProperty .


###  http://www.w3id.org/elementary#faultQuantification
:faultQuantification rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf :faultProperty .


###  http://www.w3id.org/elementary#hasStateSpecifiation
:hasStateSpecifiation rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf :requirementProperty ;
                      rdfs:comment """The state of a system, component, or the physical environment. This is specified using flexible manner. It is a string literal with just one thing compulsary: mention the language as prefix to the string with [language=..].

Examples:
[language=CNL] If the temperature of a reactor is greater than 21.5 then a cooling system must be activated within 5 seconds.

[language=STL] always[0:100] (temperature > 21.5 implies ev[0:5] (cooling_fan == ON))

[language=PSL] assert always (pressure > 15 -> eventually! (valve == OPEN)) abort (power_cut == TRUE);""" .


###  http://www.w3id.org/elementary#hasValue
:hasValue rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :variableProperty .


###  http://www.w3id.org/elementary#hasValueGreaterThan
:hasValueGreaterThan rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf :variableProperty .


###  http://www.w3id.org/elementary#hasValueLessThan
:hasValueLessThan rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :variableProperty .


###  http://www.w3id.org/elementary#isAbstract
:isAbstract rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf :componentProperty .


###  http://www.w3id.org/elementary#isOptional
:isOptional rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf :componentProperty .


###  http://www.w3id.org/elementary#mayHaveParallelInstances
:mayHaveParallelInstances rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf :variantConditionQuantification .


###  http://www.w3id.org/elementary#mayHaveSeriesInstances
:mayHaveSeriesInstances rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf :variantConditionQuantification .


###  http://www.w3id.org/elementary#modelName
:modelName rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :componentProperty .


###  http://www.w3id.org/elementary#programArtifact
:programArtifact rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :externalResource ;
                 rdfs:range xsd:anyURI .


###  http://www.w3id.org/elementary#requirementProperty
:requirementProperty rdf:type owl:DatatypeProperty .


###  http://www.w3id.org/elementary#riskPriorityNumber
:riskPriorityNumber rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :faultQuantification .


###  http://www.w3id.org/elementary#serialNumber
:serialNumber rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :componentProperty .


###  http://www.w3id.org/elementary#variableProperty
:variableProperty rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty .


###  http://www.w3id.org/elementary#variantConditionQuantification
:variantConditionQuantification rdf:type owl:DatatypeProperty ;
                                rdfs:subPropertyOf :componentProperty .



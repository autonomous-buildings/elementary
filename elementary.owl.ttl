  rdfs:comment "The variable that can be changed by an external agent" .

:hasInlet a owl:ObjectProperty;
  rdfs:subPropertyOf :hasConnectionPoint;
  owl:propertyChainAxiom _:genid12 .

_:genid12 a rdf:List;
  rdf:first :hasConnectionPoint;
  rdf:rest rdf:nil .

:hasInput a owl:ObjectProperty;

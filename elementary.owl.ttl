###  http://www.w3id.org/elementary#PhysicalMechanism
:PhysicalMechanism rdf:type owl:Class ;
                   rdfs:subClassOf :QualitativeModel ,
                                   [ owl:intersectionOf ( :PhysicalMechanism
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasDependentVariable ;
                                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass :ProcessVariable
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ,
                                   [ owl:intersectionOf ( :PhysicalMechanism
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasIndependentVariable ;
                                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass :ProcessVariable
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .



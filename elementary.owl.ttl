:datapointOf a owl:ObjectProperty;
  rdfs:subPropertyOf :automationRelation .

:dealsWithStuff a owl:ObjectProperty;
  rdfs:subPropertyOf :physicalProcessRelation;
  rdfs:domain _:genid4;
  rdfs:range :PhysicalStuff .

_:genid4 a owl:Class;
  owl:unionOf _:genid6 .


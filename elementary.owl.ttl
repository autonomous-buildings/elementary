:PhysicalMechanism a owl:Class;
  rdfs:subClassOf :QualitativeModel, _:genid17, _:genid21 .

_:genid17 a owl:Class;
  owl:intersectionOf _:genid20 .

_:genid20 a rdf:List;
  rdf:first :PhysicalMechanism;
  rdf:rest _:genid18 .

_:genid18 a rdf:List;
  rdf:first _:genid19;
  rdf:rest rdf:nil .

_:genid19 a owl:Restriction;
  owl:onClass :ProcessVariable;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :hasDependentVariable .

_:genid21 a owl:Class;
  owl:intersectionOf _:genid24 .

_:genid24 a rdf:List;
  rdf:first :PhysicalMechanism;
  rdf:rest _:genid22 .

_:genid22 a rdf:List;
  rdf:first _:genid23;
  rdf:rest rdf:nil .

_:genid23 a owl:Restriction;
  owl:onClass :ProcessVariable;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :hasIndependentVariable .

